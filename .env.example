# Anthropic Claude API (used by the Health Topic Agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# EPA AirNow API (Air Quality data)
AIRNOW_API_KEY=your_airnow_api_key_here

# Delphi Epidata API (Flu data) — public, no key required
DELPHI_EPIDATA_BASE_URL=https://api.delphi.cmu.edu/epidata

# CDC NNDSS via Socrata Open Data API (Disease Outbreak data)
CDC_NNDSS_BASE_URL=https://data.cdc.gov/resource

# Note: In this project, these keys are configured as Lovable Cloud secrets
# (Cloud -> Secrets), not read from a local .env file. This file documents
# which keys are required if you fork the project into your own workspace.
